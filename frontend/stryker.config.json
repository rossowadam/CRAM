{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "concurrency": 2,
  "mutate": [
    "src/api/**/*.ts",
    "src/utils/**/*.ts",
    "!src/**/*.spec.ts"
  ],
  "vitest": {
    "configFile": "vite.config.ts"
  },
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "reporters": [
    "progress",
    "clear-text",
    "html"
  ],
  "coverageAnalysis": "perTest"
}